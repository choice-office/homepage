# Site URL (sitemap, robots, OG 메타데이터에 사용)
NEXT_PUBLIC_SITE_URL=https://example.com

# Google Analytics (선택 — 값 넣으면 layout.tsx에서 자동 활성화)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── 문의 폼 통합 ────────────────────────────────────────────────────────────────
#
# 기본 권장 흐름: Supabase 저장 → Resend 알림 이메일 (둘 다 선택, 동시 사용 가능)
# 설정 방법: SETUP.md 6단계 참고
#
# Step 1: Supabase — contacts 테이블에 저장 (pnpm add @supabase/supabase-js 필요)
# SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxx   # 서버 전용 — NEXT_PUBLIC_ 붙이지 않음
#
# Step 2: Resend — 알림 이메일 발송 (pnpm add resend 필요, Verified Domain 등록 필수)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# CONTACT_EMAIL=hello@클라이언트도메인.com
